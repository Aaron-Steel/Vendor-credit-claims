# Copy to .env and fill in.  Used by docker-compose.basic.yml.
#
# The only value the compose file needs is the name of the docker network Caddy is on.
# Find it on the droplet with:
#   docker inspect $(docker ps --filter name=caddy -q) -f '{{json .NetworkSettings.Networks}}'
CADDY_NETWORK=root_default

# Shared login the app checks on its /login page. Share these with your testers.
# If APP_PASSWORD is left blank, the app disables auth entirely — don't do that in prod.
APP_USERNAME=macgear
APP_PASSWORD=ChooseAStrongSharedPassword
# Secret that signs the login cookie. Generate with: openssl rand -hex 32
# Keep it stable — changing it signs everyone out. Don't commit the real value.
APP_SECRET=

# (informational only — the hostname goes in the Caddyfile, not here)
# APP_HOSTNAME=claims.yourcompany.com

# Shared secret for the daily NetSuite pricing sync (n8n sends it in the X-Sync-Token
# header to POST /admin/sync-pricing). Generate one with: openssl rand -hex 24
# Leave blank to disable the sync endpoint entirely.
PRICING_SYNC_TOKEN=
