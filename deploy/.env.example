# Copy to `.env` and fill in. Never commit the real .env.

# --- Your deployment ---------------------------------------------------------
APP_HOSTNAME=claims.yourcompany.com         # the subdomain users will visit
ALLOWED_EMAIL_DOMAIN=macgeargroup.com       # only this email domain may sign in
CADDY_NETWORK=root_default                   # docker network Caddy is on (find it: see DEPLOY.md)

# --- Microsoft Entra (Azure AD) app registration ----------------------------
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
OAUTH2_PROXY_CLIENT_ID=00000000-0000-0000-0000-000000000000
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret-value

# --- oauth2-proxy session cookie --------------------------------------------
# Generate with:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64-secret
